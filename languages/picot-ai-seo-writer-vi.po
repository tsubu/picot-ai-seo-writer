#: includes/admin/class-settings-page.php
msgid ""
"WordPress AI Client is unavailable. Install the Google Gemini connector."
msgstr ""
"Ứng dụng khách WordPress AI không khả dụng. Cài đặt trình kết nối Google "
"Gemini."

#: includes/admin/class-settings-page.php
msgid ""
"No Gemini models were found. Check the Google Gemini connector connection."
msgstr ""
"Không có mô hình Gemini nào được tìm thấy. Kiểm tra kết nối trình kết nối "
"Google Gemini."

#: includes/admin/class-settings-page.php
msgid "Hello"
msgstr "Xin chào"

#: includes/admin/class-settings-page.php
#: includes/rest/class-models-endpoint.php
msgid ""
"Google Gemini connector is not configured. Connect Gemini under Settings → "
"Connectors."
msgstr ""
"Trình kết nối Google Gemini chưa được định cấu hình. Kết nối Gemini trong "
"Cài đặt → Trình kết nối."

#: includes/admin/class-settings-page.php
msgid "Successfully connected to the Google Gemini connector."
msgstr "Đã kết nối thành công với trình kết nối Google Gemini."

#: includes/api/class-gemini-client.php includes/api/class-image-generator.php
msgid ""
"WordPress AI Client is not available. Install and configure the Google "
"Gemini connector under Settings → Connectors."
msgstr ""
"Ứng dụng khách WordPress AI không có sẵn. Cài đặt và định cấu hình trình kết"
" nối Google Gemini trong Cài đặt → Trình kết nối."

#: includes/api/class-gemini-client.php
msgid "Text model is not set. Choose one on the settings screen."
msgstr "Mẫu văn bản chưa được đặt. Chọn một trên màn hình cài đặt."

#: includes/api/class-gemini-client.php
msgid "The prompt is empty."
msgstr "Lời nhắc trống."

#: includes/api/class-gemini-client.php
msgid ""
"The selected Gemini model does not support text generation. Check the Google"
" Gemini connector settings."
msgstr ""
"Mô hình Gemini đã chọn không hỗ trợ tạo văn bản. Kiểm tra cài đặt trình kết "
"nối Google Gemini."

#: includes/api/class-image-generator.php
msgid "Image model is not set. Choose one on the settings screen."
msgstr "Mô hình hình ảnh chưa được thiết lập. Chọn một trên màn hình cài đặt."

#: includes/api/class-image-generator.php
msgid ""
"The selected Gemini model does not support image generation. Check the "
"Google Gemini connector settings."
msgstr ""
"Mô hình Gemini đã chọn không hỗ trợ tạo hình ảnh. Kiểm tra cài đặt trình kết"
" nối Google Gemini."

#: includes/api/class-image-generator.php
msgid "No image data was returned."
msgstr "Không có dữ liệu hình ảnh được trả lại."

#: includes/api/class-model-manager.php
msgid ""
"Failed to fetch Gemini models. Check the Google Gemini connector API key."
msgstr ""
"Không tìm nạp được mô hình Gemini. Kiểm tra khóa API của trình kết nối "
"Google Gemini."

